---
import { getYouTubeEmbedUrl, getYouTubeThumbnail } from '../utils/youtube';

const works = [
	{ id: '1', title: 'The Herald', video: 'https://www.youtube.com/watch?v=LrbQWDBquDM' },
	{ id: '2', title: 'Get it Right', video: 'https://www.youtube.com/watch?v=62F-0we6lic' },
	{ id: '3', title: 'Little Bird', video: 'https://www.youtube.com/watch?v=7ow0SMlbrEI' },
	{ id: '4', title: 'What We`re Living For', video: 'https://www.youtube.com/watch?v=FbYpYisgV78' },
	{ id: '5', title: 'Days are Gone', video: 'https://www.youtube.com/watch?v=orMPOJrb6ps' },
	{ id: '6', title: 'Something I Said', video: 'https://www.youtube.com/watch?v=gW98PBrn8ts' },
	{ id: '7', title: 'Things We Call Life', video: 'https://www.youtube.com/watch?v=caUedxdVWkU' },
	{ id: '8', title: 'Pulse', video: '' },
].map((work) => ({
	...work,
	thumb: getYouTubeThumbnail(work.video),
	video: getYouTubeEmbedUrl(work.video),
}));
---

<section class="work section" id="portfolio">
	<div class="container">
		<div class="section-heading">
			<h2>Recent Lyric Videos</h2>
			<span class="underline"></span>
		</div>

		<div class="grid">
			{works.map((work) => (
				<button
					class="grid-item"
					type="button"
					data-video={work.video}
					data-title={work.title}
					aria-label={`Play ${work.title}`}
				>
					<img
						src={work.thumb}
						alt={work.title}
						width="260"
						height="146"
						loading="lazy"
						onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','mqdefault')"
					/>
					<span class="overlay">
						<span class="play-icon">▶</span>
					</span>
				</button>
			))}
		</div>
	</div>
</section>

<style>
	.work {
		background: var(--color-bg);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 4px;
	}

	.grid-item {
		position: relative;
		padding: 0;
		border: none;
		background: none;
		aspect-ratio: 1;
		overflow: hidden;
		cursor: pointer;
	}

	.grid-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s ease;
	}

	.overlay {
		position: absolute;
		inset: 0;
		background: rgba(28, 28, 30, 0);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.3s;
	}

	.play-icon {
		font-size: 1.5rem;
		color: #ffffff;
		opacity: 0;
		transform: scale(0.8);
		transition: opacity 0.3s, transform 0.3s;
	}

	.grid-item:hover img {
		transform: scale(1.06);
	}

	.grid-item:hover .overlay {
		background: rgba(28, 28, 30, 0.45);
	}

	.grid-item:hover .play-icon {
		opacity: 1;
		transform: scale(1);
	}

	@media (max-width: 900px) {
		.grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 600px) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
