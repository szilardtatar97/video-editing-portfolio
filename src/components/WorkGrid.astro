---
import { getYouTubeEmbedUrl, getYouTubeThumbnail } from "../utils/youtube";
const works = [
  {
    id: "1",
    title: "The Herald",
    video: "https://www.youtube.com/watch?v=LrbQWDBquDM",
  },
  {
    id: "2",
    title: "Get it Right",
    video: "https://www.youtube.com/watch?v=62F-0we6lic",
  },
  {
    id: "3",
    title: "Little Bird",
    video: "https://www.youtube.com/watch?v=7ow0SMlbrEI&t=2s",
  },
  {
    id: "4",
    title: "What We`re Living For",
    video: "https://www.youtube.com/watch?v=FbYpYisgV78",
  },
  {
    id: "5",
    title: "Days are Gone",
    video: "https://www.youtube.com/watch?v=orMPOJrb6ps",
  },
  {
    id: "6",
    title: "Something I Said",
    video: "https://www.youtube.com/watch?v=gW98PBrn8ts",
  },
  {
    id: "7",
    title: "Things We Call Life",
    video: "https://www.youtube.com/watch?v=caUedxdVWkU",
  },
  { id: "8", title: "Pulse", video: "" },
].map((work) => ({
  ...work,
  thumb: getYouTubeThumbnail(work.video),
  embedUrl: getYouTubeEmbedUrl(work.video),
}));
---

<section class="work section" id="portfolio">
  <div class="container">
    <div class="section-heading">
      <h2>Recent Lyric Videos</h2>
      <span class="underline"></span>
    </div>

    <div class="grid">
      {
        works.map((work) => (
          <button
            class="grid-item"
            type="button"
            data-video={work.embedUrl}
            data-title={work.title}
            disabled={!work.embedUrl}
            aria-label={`Play ${work.title}`}
          >
            <img
              src={work.thumb}
              alt={work.title}
              width="260"
              height="146"
              loading="lazy"
              onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','mqdefault')"
            />
            <span class="overlay">
              <span class="play-icon">▶</span>
            </span>
          </button>
        ))
      }
    </div>
  </div>
</section>

<div class="video-modal" hidden aria-hidden="true">
  <button class="video-modal-backdrop" type="button" aria-label="Close video"></button>
  <div class="video-modal-dialog" role="dialog" aria-modal="true">
    <button class="video-modal-close" type="button" aria-label="Close video">
      ×
    </button>
    <iframe
      title="YouTube video player"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
</div>

<style>
  .work {
    background: var(--color-bg);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
  }

  .grid-item {
    position: relative;
    padding: 0;
    border: none;
    background: none;
    aspect-ratio: 1;
    overflow: hidden;
    cursor: pointer;
  }

  .grid-item:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(28, 28, 30, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s;
  }

  .play-icon {
    font-size: 1.5rem;
    color: #ffffff;
    opacity: 0;
    transform: scale(0.8);
    transition:
      opacity 0.3s,
      transform 0.3s;
  }

  .grid-item:hover:not(:disabled) img {
    transform: scale(1.06);
  }

  .grid-item:hover:not(:disabled) .overlay {
    background: rgba(28, 28, 30, 0.45);
  }

  .grid-item:hover:not(:disabled) .play-icon {
    opacity: 1;
    transform: scale(1);
  }

  .video-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .video-modal[hidden] {
    display: none;
  }

  .video-modal-backdrop {
    position: absolute;
    inset: 0;
    border: none;
    background: rgba(0, 0, 0, 0.85);
    cursor: pointer;
  }

  .video-modal-dialog {
    position: relative;
    width: min(960px, 100%);
    aspect-ratio: 16 / 9;
    z-index: 1;
  }

  .video-modal-dialog iframe {
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 4px;
  }

  .video-modal-close {
    position: absolute;
    top: -2.5rem;
    right: 0;
    border: none;
    background: none;
    color: #fff;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    padding: 0;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .video-modal-close {
      top: -2rem;
      font-size: 1.5rem;
    }
  }
</style>

<script>
  const modal = document.querySelector(".video-modal") as HTMLDivElement;
  const iframe = modal.querySelector("iframe") as HTMLIFrameElement;
  const backdrop = modal.querySelector(".video-modal-backdrop") as HTMLButtonElement;
  const closeBtn = modal.querySelector(".video-modal-close") as HTMLButtonElement;

  function closeModal() {
    iframe.src = "";
    modal.hidden = true;
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  function openModal(url: string) {
    iframe.src = url;
    modal.hidden = false;
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    closeBtn.focus();
  }

  document.querySelectorAll<HTMLButtonElement>(".grid-item[data-video]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const url = btn.dataset.video;
      if (url) openModal(url);
    });
  });

  backdrop.addEventListener("click", closeModal);
  closeBtn.addEventListener("click", closeModal);

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && !modal.hidden) closeModal();
  });
</script>