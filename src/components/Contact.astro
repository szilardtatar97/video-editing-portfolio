---
---

<section class="contact section" id="contact">
	<div class="container">
		<div class="section-heading">
			<h2>Get in Touch</h2>
			<span class="underline"></span>
			<p class="subtitle">Ready to bring your music to life? Let's talk.</p>
		</div>

		<div class="contact-grid">
			<form class="contact-form" action="mailto:szilardtatar97@gmail.com" method="post">
				<div class="field">
					<label for="name">Name</label>
					<input type="text" id="name" name="name" required placeholder="Your name" />
				</div>
				<div class="field">
					<label for="email">Email</label>
					<input type="email" id="email" name="email" required placeholder="you@email.com" />
				</div>
				<div class="field">
					<label for="message">Message</label>
					<textarea
						id="message"
						name="message"
						rows="5"
						required
						placeholder="Tell me about your project — song link, style references, deadline..."
					></textarea>
				</div>
				<button type="submit" class="btn-accent">Send Message</button>
			</form>

			<div class="contact-info">
				<div class="info-block">
					<span class="info-icon">✉</span>
					<div>
						<strong>Email</strong>
						<a href="mailto:szilardtatar97@gmail.com">szilardtatar97@gmail.com</a>
					</div>
				</div>
				<div class="info-block">
					<span class="info-icon">◎</span>
					<div>
						<strong>Social</strong>
						<p>
							<a href="https://www.instagram.com/tatar.szili/" target="_blank" rel="noopener noreferrer">Instagram</a>
							&nbsp;·&nbsp;
							<a href="https://www.youtube.com/@szilardtatar97" target="_blank" rel="noopener noreferrer">YouTube</a>
						</p>
					</div>
				</div>
				<div class="info-block">
					<span class="info-icon">⏱</span>
					<div>
						<strong>Response Time</strong>
						<p>Usually within 24 hours</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<footer class="footer">
	<p>&copy; {new Date().getFullYear()} Szilard Tatar. All rights reserved.</p>
</footer>

<style>
	.subtitle {
		margin: 1rem 0 0;
		color: var(--color-muted);
		font-size: 0.9rem;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 280px;
		gap: 3rem;
		align-items: start;
	}

	.field {
		margin-bottom: 1.25rem;
	}

	.field label {
		display: block;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: 0.4rem;
		color: var(--color-muted);
	}

	.field input,
	.field textarea {
		width: 100%;
		padding: 0.75rem 1rem;
		border: 1px solid #e0e0e0;
		border-radius: 4px;
		font-family: inherit;
		font-size: 0.9rem;
		background: transparent;
		transition: border-color 0.2s;
		resize: vertical;
	}

	.field input:focus,
	.field textarea:focus {
		outline: none;
		border-color: var(--color-accent);
	}

	.btn-accent {
		padding: 0.9rem 2rem;
		background: var(--color-accent);
		color: #ffffff;
		border: none;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		transition: background 0.2s;
	}

	.btn-accent:hover {
		background: var(--color-accent-hover);
	}

	.contact-info {
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
		padding-top: 0.5rem;
	}

	.info-block {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
	}

	.info-icon {
		font-size: 1.3rem;
		color: var(--color-accent);
		flex-shrink: 0;
	}

	.info-block strong {
		display: block;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: 0.25rem;
	}

	.info-block p,
	.info-block a {
		font-size: 0.85rem;
		color: var(--color-muted);
		margin: 0;
	}

	.info-block a:hover {
		color: var(--color-accent);
	}

	.footer {
		background: var(--color-dark);
		color: rgba(255, 255, 255, 0.5);
		text-align: center;
		padding: 1.25rem;
		font-size: 0.75rem;
	}

	.footer p {
		margin: 0;
	}

	@media (max-width: 768px) {
		.contact-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
